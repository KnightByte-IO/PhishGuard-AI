# Server port
PORT=5000

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/phishguard-ai

# Secret key for signing JWT tokens (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Token expiry (e.g. 7d = 7 days, 24h = 24 hours)
JWT_EXPIRES_IN=7d

# Google Gemini API key (for AI threat explanations only)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (optional — defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
